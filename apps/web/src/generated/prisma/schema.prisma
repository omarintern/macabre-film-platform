// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model for the Film Collaboration Platform
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      UserRole @default(CLIENT)
  name      String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  works Work[] // One-to-many relationship with works

  @@map("users")
}

// Work model for creative content submissions
model Work {
  id             String   @id @default(cuid())
  title          String
  body           String // Max 1000 characters (enforced in validation)
  classification String // "Synopsis", "Scene Description", or "Other"
  tags           String[] // Array of tags/hashtags
  creatorId      String
  creator        User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("works")
}

enum UserRole {
  CLIENT
  CREATOR
  ADMIN
}
